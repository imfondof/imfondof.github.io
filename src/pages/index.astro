---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE_DESCRIPTION } from "../consts";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort((a, b) => {
  const aTime = a.data.pubDate?.getTime() ?? 0;
  const bTime = b.data.pubDate?.getTime() ?? 0;
  return bTime - aTime;
});

const featuredPosts = posts.slice(0, 4);
---

<BaseLayout description={SITE_DESCRIPTION}>
  <section class="hero">
    <p class="eyebrow">个人写作存档</p>
    <h1>imfondof blog</h1>
    <p class="hero-copy">
      从 Flutter Web 构建产物迁移到 Astro 后，这个站点回到了更适合内容表达的形态：
      轻量、可读、可检索，也更适合长期写作。
    </p>
    <div class="hero-actions">
      <a class="button-primary" href="/blog/">开始阅读</a>
      <a class="button-secondary" href="/rss.xml">订阅 RSS</a>
    </div>
  </section>

  <section class="section-block">
    <div class="section-head">
      <p class="eyebrow">最新文章</p>
      <h2>最近文章</h2>
    </div>
    <div class="post-grid">
      {featuredPosts.map((post) => (
        <a class="post-card" href={`/blog/${post.slug}/`}>
          <p class="post-date">
            {post.data.pubDate ? post.data.pubDate.toLocaleDateString("zh-CN") : "未标注日期"}
          </p>
          <h3>{post.data.title}</h3>
          <p>{post.data.description ?? "进入正文阅读全文。"}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
